{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Tine",
    "patterns": [
        {
            "include": "#xml-element"
        },
        {
            "include": "#xml-children"
        },
        {
            "include": "#keywords"
        },
        {
            "include": "#types"
        },
        {
            "include": "#booleans"
        },
        {
            "include": "#functions"
        },
        {
            "include": "#identifiers"
        },
        {
            "include": "#numbers"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#comments"
        }
    ],
    "repository": {
        "xml-element": {
            "name": "meta",
            "begin": "(<\/?)([A-Za-z][A-Za-z0-9\\-]*)",
            "beginCaptures": {
                "1": {
                    "name": "punctuation.definition.tag.begin.tine"
                },
                "2": {
                    "name": "entity.name.tag.open.tine"
                }
            },
            "end": "(\/?>)",
            "endCaptures": {
                "1": {
                    "name": "punctuation.definition.tag.end.tine"
                }
            },
            "patterns": [
                {
                    "include": "#xml-tag-attributes"
                }
            ]
        },
        "xml-tag-attributes": {
            "name": "meta.jsx.attributes",
            "begin": "(?<=<[^>]*)(?=[^>]*>)",
            "end": "(?=/?>)",
            "patterns": [
                {
                    "match": "\\b([A-Za-z_:][A-Za-z0-9_:\\-\\.]*)\\b",
                    "captures": {
                        "1": {
                            "name": "entity.other.attribute-name.tine"
                        }
                    }
                },
                {
                    "match": "\"[^\"]*\"",
                    "name": "string.quoted.double.tine"
                },
                {
                    "match": "'[^']*'",
                    "name": "string.quoted.single.tine"
                },
                {
                    "begin": "\\{",
                    "end": "\\}",
                    "name": "meta.embedded.expression.tine",
                    "patterns": [
                        {
                            "include": "#expressions"
                        }
                    ]
                }
            ]
        },
        "xml-children": {
            "match": "(?<=>).*?(?=<\/)",
            "name": "text.tine"
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.tine",
                    "match": "\\b(if|else|for|in|return|break|continue|match|use)\\b"
                },
                {
                    "name": "keyword.declaration.variable.tine",
                    "match": "\\b(const|var)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "name": "entity.name.type.tine",
                    "match": "\\b([A-Z][a-zA-Z0-9_]*|str|int|float|bool)\\b"
                },
                {
                    "name": "entity.name.type.tine",
                    "match": "(?<=^use)\\s+[A-Za-z_][A-Za-z0-9_]*|(?<=\\.)[A-Za-z_][A-Za-z0-9_]*"
                }
            ]
        },
        "booleans": {
            "name": "constant.language.boolean.tine",
            "match": "\\b(true|false)\\b"
        },
        "functions": {
            "patterns": [
                {
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*:(:|=)\\s*(?=\\(.*?\\)\\s*=>)",
                    "captures": {
                        "1": {
                            "name": "entity.name.function.tine"
                        }
                    }
                },
                {
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
                    "captures": {
                        "1": {
                            "name": "entity.name.function.call.tine"
                        }
                    }
                }
            ]
        },
        "identifiers": {
            "patterns": [
                {
                    "name": "variable.other.tine",
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)"
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.integer.decimal.tine",
                    "match": "\\b([0-9]+)\\b"
                },
                {
                    "name": "constant.numeric.integer.hexadecimal.tine",
                    "match": "\\b0x([0-9a-fA-F]+)\\b"
                },
                {
                    "name": "constant.numeric.integer.binary.tine",
                    "match": "\\b0b([01]+)\\b"
                },
                {
                    "name": "constant.numeric.float.tine",
                    "match": "\\b([0-9]+\\.[0-9]*)([eE][+-]?[0-9]+)?\\b"
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.tine",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.tine",
                    "match": "\\\\."
                }
            ]
        },
        "comments": {
            "name": "comment.line.double-slash.tine",
            "begin": "//",
            "end": "$"
        }
    },
    "scopeName": "source.tine"
}