{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "MyLang",
    "patterns": [
        {
            "include": "#identifiers"
        },
        {
            "include": "#types"
        }
    ],
    "repository": {
        "types": {
            "patterns": [
                {
                    "name": "entity.name.type.my",
                    "match": "\\b([A-Z][a-zA-Z0-9_]*|string|number|boolean)\\b"
                },
                {
                    "name": "entity.name.type.my",
                    "match": "(?<=^use)\\s+[A-Za-z_][A-Za-z0-9_]*|(?<=\\.)[A-Za-z_][A-Za-z0-9_]*"
                }
            ]
        },
        "identifiers": {
            "patterns": [
                {
                    "name": "variable.other.my",
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s+(?=:)"
                }
            ]
        }
    },
    "scopeName": "source.mylang-types"
}