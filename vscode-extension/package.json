{
  "name": "vscode-extension",
  "displayName": "MyLang",
  "description": "VS Code support for MyLang",
  "version": "0.1.0",
  "publisher": "your-name",
  "engines": {
    "vscode": "^1.105.0"
  },
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "my-lang",
        "aliases": [
          "MyLang",
          "my-lang"
        ],
        "extensions": [
          ".my"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "my-lang",
        "scopeName": "source.my",
        "path": "./syntaxes/my.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npx tsc -p ./",
    "compile": "npx tsc -p ./",
    "watch": "npx tsc -watch -p ./",
    "package": "vsce package"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@types/vscode": "^1.105.0",
    "@vscode/test-electron": "^2.5.2",
    "typescript": "^5.9.3",
    "vscode-test": "^1.6.1"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}