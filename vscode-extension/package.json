{
  "name": "vscode-extension",
  "displayName": "MyLang",
  "description": "VS Code support for MyLang",
  "version": "0.1.0",
  "publisher": "bmelicque",
  "engines": {
    "vscode": "^1.105.0"
  },
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "my-lang",
        "aliases": [
          "MyLang"
        ],
        "extensions": [
          ".my"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "my-lang",
        "scopeName": "source.my",
        "path": "./syntaxes/my.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npx tsc -p ./",
    "compile": "npx tsc -p ./",
    "watch": "npx tsc -watch -p ./",
    "build:server": "cd ../crates/server && cargo build --release",
    "copy:server": "mkdir -p ./server/bin && cp ../target/release/mylang_server ./server/bin/",
    "copy:server:win": "mkdir server\\bin 2> NUL & copy ..\\target\\release\\mylang_server.exe server\\bin\\",
    "build:extension": "vsce package",
    "install:extension": "node -e \"const fs=require('fs');const{execSync}=require('child_process');const vsix=fs.readdirSync('.').find(f=>f.endsWith('.vsix'));if(!vsix)throw new Error('No VSIX found');execSync(`code --install-extension ${vsix}`,{stdio:'inherit'})\"",
    "build:all": "npm run build:server && npm run copy:server:win && npm run build:extension && npm run install:extension"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@types/vscode": "^1.105.0",
    "@vscode/test-electron": "^2.5.2",
    "typescript": "^5.9.3",
    "vscode-test": "^1.6.1"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}